// ═══════════════════════════════════════════
// XAI / GROK CALL
// ═══════════════════════════════════════════
async function callMarcus(userMsg) {
  const sys = buildSys();
  const hist = S.chatHistory.slice(-16).map(m=>({
    role: m.role==='user'?'user':'assistant',
    content: m.text
  }));
  const schema = `

CRITICAL: Respond ONLY with a valid JSON object. No text outside it. No markdown. Format:
{
  "reply": "your conversational message as plain text (use \\n for line breaks)",
  "hasWorkout": false,
  "workout": null,
  "hasPlan": false,
  "plan": null,
  "suggestions": ["follow-up 1", "follow-up 2", "follow-up 3"]
}
When giving a workout: hasWorkout:true, workout:{"name":"...","exercises":[{"name":"Exercise","sets":"4","reps":"8-12","muscle":"Chest","note":"coaching tip or cue"}]}
When giving a weekly plan: hasPlan:true, plan:{"days":[{"day":"Monday","focus":"Upper Push","type":"training","exercises":["Bench Press","OHP","Incline DB","Tricep Dips","Lateral Raises"]},{"day":"Sunday","focus":"Rest","type":"rest","exercises":[]}]}
suggestions: 2-3 natural short follow-up questions or requests the user might say.
ONLY the JSON. Nothing else.`;

  const messages = [
    {role:'system', content:sys},
    ...hist,
    {role:'user', content:userMsg+schema}
  ];

  const res = await fetch(XAI_URL, {
    method:'POST',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+XAI_KEY},
    body:JSON.stringify({model:XAI_MODEL, messages, temperature:0.88, max_tokens:2400})
  });

  if (!res.ok) {
    const e = await res.json().catch(()=>({}));
    throw new Error(e?.error?.message || `Connection error ${res.status}`);
  }
  const data = await res.json();
  const raw = data.choices?.[0]?.message?.content || '{}';
  let parsed;
  try { parsed = JSON.parse((raw.match(/\{[\s\S]*\}/)||[raw])[0]); }
  catch(e) { return {text:raw, html:fmtText(raw), suggestions:[]}; }

  let html = fmtText(parsed.reply||'');
  if (parsed.hasWorkout && parsed.workout) {
    html += mkWkCard(parsed.workout);
    S.todayExs = (parsed.workout.exercises||[]).map(e=>({...e,done:false}));
    saveState(); renderTodayExs();
  }
  if (parsed.hasPlan && parsed.plan) html += mkPlanCard(parsed.plan);
  return {text:parsed.reply||raw, html, suggestions:parsed.suggestions||[]};
}

function buildSys() {
  const goalMap = {
    muscle_athletic:'build serious muscle mass AND become more athletic — size and performance together',
    pure_muscle:'maximize muscle hypertrophy and size',
    fat_loss:'lose body fat while preserving and building muscle',
    strength:'build raw strength and power'
  };
  return `You are Marcus — an elite AI personal trainer and strength coach. You are direct, knowledgeable, and talk exactly like a real experienced trainer. You are NOT a bot, NOT an assistant, and you NEVER sound like one.

PERSONALITY & COMMUNICATION:
- Talk naturally. Contractions. Real sentences. Say things like "Look," "Here's the deal," "Real talk," "Honestly," "Let me be straight with you," "Not gonna lie."
- Be direct and confident. Never hedge or give vague advice.
- When someone tells you they're tired, sore, or had a bad week — respond like a human first, then coach.
- Ask follow-up questions when you need more info. Never just dump a plan without context.
- You remember everything the user tells you in this conversation and reference it back.
- NEVER say "Certainly!" "Of course!" "As an AI" "I'd be happy to" or anything robotic.
- Mild swearing is fine if the vibe calls for it.
- You genuinely care about people getting results. You push them, but you're smart about it.

TRAINING EXPERTISE — You know this cold:
HYPERTROPHY: progressive overload, mechanical tension, metabolic stress, muscle damage, volume landmarks (MEV/MAV/MRV), RIR-based training, frequency per muscle group (2-3x/week optimal), rep ranges (6-20 all stimulate growth), compound-first ordering, isolation finishers, mind-muscle connection cues, tempo manipulation, drop sets, supersets, rest-pause, myorep sets.
STRENGTH: periodization (linear, undulating, block), 1RM percentages, RPE/RIR, SBD technique, powerbuilding programming, conjugate method, peaking protocols.
PROGRAMS: PPL (Push Pull Legs), Upper/Lower 4-day, Full Body 3-day, Bro split, Arnold split, PHUL, PHAT, 5/3/1, GZCLP. Know the pros/cons of each for different goals.
NUTRITION: TDEE calculation, caloric surplus for lean bulk (200-500 kcal), deficit for cut (300-500 kcal), protein targets (0.7-1g/lb BW for muscle), carb timing around training, fat minimums, meal frequency myths, bulking vs cutting timing, body recomposition for beginners/intermediates, creatine dosing (5g/day), pre-workout nutrition, post-workout window (less critical than once thought).
INJURY & RECOVERY: common gym injuries (shoulder impingement, knee tracking, lower back strain), deload protocols (every 4-8 weeks), sleep importance, DOMS vs real injury, mobility work, foam rolling (limited evidence but psychological benefit), active recovery.
ATHLETIC PERFORMANCE: power development (plyometrics, Olympic lifting variations), speed work, conditioning without killing gains (LISS vs HIIT tradeoffs), sport-specific training principles.

WHEN BUILDING WORKOUTS: Give specific sets/reps with proper progressive overload built in. Include coaching cues for key movements. Consider the user's level and any injuries.
WHEN BUILDING PROGRAMS: Ask about schedule, available equipment, time per session, weak points, injury history before building. Then deliver a complete, periodized program.

USER PROFILE:
- Name: ${U?.name||S.name||'unknown'}
- Age: ${S.age||'unknown'}
- Goal: ${goalMap[S.goal]||'build muscle and athleticism'}
- Training style: ${S.style||'everything'}
- Level: ${S.level||'intermediate'}
- Days/week: ${S.days||'5'}
- Injuries/notes: ${S.injuries||'none mentioned'}
${S.weight?`- Weight: ${S.weight}`:''}
${S.height?`- Height: ${S.height}`:''}

Always personalize everything to this person. Reference their profile. If you're missing info you need, ask for it first.`;
}

function fmtText(text) {
  if (!text) return '';
  return text
    .replace(/\*\*(.*?)\*\*/g,'<strong style="color:var(--white);font-weight:500">$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/^### (.+)$/gm,'<div style="font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:14px;letter-spacing:2px;text-transform:uppercase;color:var(--orange);margin:12px 0 4px">$1</div>')
    .replace(/^## (.+)$/gm,'<div style="font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:16px;letter-spacing:2px;text-transform:uppercase;margin:13px 0 6px">$1</div>')
    .replace(/^(\d+)\. (.+)$/gm,'<div style="display:flex;gap:7px;margin:3px 0"><span style="color:var(--orange);font-family:\'JetBrains Mono\',monospace;font-size:10px;min-width:16px;padding-top:3px">$1.</span><span>$2</span></div>')
    .replace(/^[•\-] (.+)$/gm,'<div style="display:flex;gap:7px;margin:3px 0"><span style="color:var(--orange);padding-top:3px;font-size:10px">▸</span><span>$1</span></div>')
    .replace(/\n\n/g,'<div style="height:7px"></div>')
    .replace(/\n/g,'<br>');
}

function mkWkCard(w) {
  const rows = (w.exercises||[]).map((ex,i)=>`<tr>
    <td style="color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:9px">${String(i+1).padStart(2,'0')}</td>
    <td style="font-weight:500;font-size:12.5px">${ex.name}</td>
    <td style="font-family:'JetBrains Mono',monospace;font-size:10.5px">${ex.sets}×${ex.reps}</td>
    <td><span class="mtag">${ex.muscle}</span></td>
    <td style="font-size:11px;color:var(--m2)">${ex.note||'—'}</td>
  </tr>`).join('');
  return `<div class="wk-card"><div class="wk-hd"><span class="wk-title">${w.name||"Today's Workout"}</span><button class="btn btn-g btn-xs" onclick="showPanel('dash')">▶ Today</button></div>
  <table class="wk-tbl"><thead><tr><th>#</th><th>Exercise</th><th>Sets×Reps</th><th>Muscle</th><th>Coach Notes</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

function mkPlanCard(p) {
  const days = Array.isArray(p)?p:(p.days||[]);
  return `<div class="plan-card">${days.map(d=>`<div class="plan-row">
    <div class="plan-day">${(d.day||'').slice(0,3)}</div>
    <div><div class="plan-focus">${d.focus||'Rest'}</div>${d.exercises?.length&&d.type!=='rest'?`<div class="plan-exs">${d.exercises.slice(0,4).join(' · ')}</div>`:''}</div>
  </div>`).join('')}</div>`;
}

