<script>
// ═══════════════════════════════════════════
// CONFIG — xAI API
// ═══════════════════════════════════════════
const XAI_KEY = 'Placeholder';
const XAI_URL = 'https://api.x.ai/v1/chat/completions';
const XAI_MODEL = 'grok-2-latest';

// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
const MSG_LIMITS = {free:20, pro:Infinity, elite:Infinity};
let U = null; // current user
let S = {
  style:'everything',level:'intermediate',days:'5',injuries:'',weight:'',height:'',
  streak:0,totalSessions:0,weekSessions:0,lastSession:null,
  history:[],todayExs:[],chatHistory:[],onboarded:false,
  plan:'free',msgCount:0,selectedGoal:'muscle_athletic',goal:'muscle_athletic'
};

const lsGet = k => { try { return JSON.parse(localStorage.getItem(k)) } catch(e) { return null } };
const lsSet = (k,v) => { try { localStorage.setItem(k, JSON.stringify(v)) } catch(e) {} };

// ═══════════════════════════════════════════
// SCREEN ROUTING
// ═══════════════════════════════════════════
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(name+'Screen').classList.add('active');
  if (name === 'login' || name === 'signup') {
    ['loginScreen','signupScreen'].forEach(id => {
      const el = document.getElementById(id);
      el.style.display = (id === name+'Screen') ? 'flex' : 'none';
      el.classList.toggle('active', id === name+'Screen');
    });
  }
}

document.addEventListener('DOMContentLoaded', () => {
  // Fix auth screens to flex
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('signupScreen').style.display = 'none';

  const saved = lsGet('apex_user');
  if (saved) {
    U = saved;
    S = {...S, ...lsGet('apex_state_'+U.email)} || S;
    bootApp();
  }
  buildWeekRow();
});

// ═══════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════
function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass = document.getElementById('loginPass').value;
  const err = document.getElementById('loginErr');
  err.className = 'auth-err';
  if (!email || !pass) { err.textContent = 'Please fill in all fields.'; err.className = 'auth-err show'; return; }
  const users = lsGet('apex_users') || {};
  if (!users[email] || users[email].pass !== btoa(pass)) {
    err.textContent = 'Invalid email or password.'; err.className = 'auth-err show'; return;
  }
  U = users[email];
  lsSet('apex_user', U);
  S = {...S, ...lsGet('apex_state_'+email)};
  bootApp();
}

