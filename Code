async function sendMsg() {
  const ta = document.getElementById('chatIn');
  const text = ta.value.trim();
  if (!text || document.getElementById('sendBtn').disabled) return;
  const limit = MSG_LIMITS[S.plan||'free'];
  if ((S.msgCount||0) >= limit) {
    showErr(`You've reached your ${S.plan==='free'?'20 message free limit':'limit'}. Upgrade your plan.`);
    setTimeout(()=>showPanel('sub'),1800); return;
  }
  ta.value=''; ta.style.height='auto';
  hideErr(); clearQRs();
  appendMsg('user', text, true);
  S.chatHistory.push({role:'user',text,html:text});
  S.msgCount = (S.msgCount||0)+1;
  saveState();
  document.getElementById('sendBtn').disabled = true;
  const tid = showTyping();
  try {
    const {text:rt, html, suggestions} = await callMarcus(text);
    removeTyping(tid);
    marcusSays(html||rt, suggestions||[]);
    S.chatHistory.push({role:'marcus',text:rt,html:html||rt});
    saveState();
  } catch(e) {
    removeTyping(tid);
    showErr(e.message||'Connection issue. Try again.');
  }
  document.getElementById('sendBtn').disabled = false;
}

function marcusSays(html, sugs) {
  appendMsg('marcus', html, true);
  if (sugs?.length) setQRs(sugs);
}

