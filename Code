<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX — Elite AI Training</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#09090C;--s1:#111115;--s2:#17171D;--s3:#1E1E26;
  --border:rgba(255,255,255,0.055);--b2:rgba(255,255,255,0.1);
  --white:#EDEAE3;--muted:#52526A;--m2:#8A8AA2;
  --orange:#F04E23;--od:rgba(240,78,35,0.1);--og:rgba(240,78,35,0.2);
  --green:#1DB954;--blue:#3B82F6;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--white);font-family:'Barlow',sans-serif;font-weight:300;overflow-x:hidden}

/* ── UTILS ── */
.mono{font-family:'JetBrains Mono',monospace}
.cond{font-family:'Barlow Condensed',sans-serif}
.btn{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:9px 18px;border:none;cursor:pointer;transition:all 0.18s;display:inline-flex;align-items:center;gap:7px;border-radius:7px;font-weight:500;white-space:nowrap}
.btn-p{background:var(--orange);color:white}
.btn-p:hover{background:#f5613a;transform:translateY(-1px);box-shadow:0 4px 20px rgba(240,78,35,0.35)}
.btn-g{background:var(--s2);color:var(--m2);border:1px solid var(--border)}
.btn-g:hover{color:var(--white);border-color:var(--b2)}
.btn-outline{background:transparent;color:var(--white);border:1px solid rgba(255,255,255,0.2)}
.btn-outline:hover{border-color:var(--white);background:rgba(255,255,255,0.05)}
.btn-lg{padding:14px 32px;font-size:11px;border-radius:8px}
.btn-sm{padding:6px 12px;font-size:9px}
.btn-xs{padding:3px 9px;font-size:8.5px}
.btn-danger{background:rgba(239,68,68,0.08);color:#f87171;border:1px solid rgba(239,68,68,0.18)}
.btn-danger:hover{background:rgba(239,68,68,0.15)}

/* ══════════════════════════════
   SCREENS
══════════════════════════════ */
.screen{display:none;min-height:100vh}
.screen.active{display:block}

/* ══════════════════════════════
   HOME / LANDING
══════════════════════════════ */
#homeScreen{background:var(--bg);overflow-x:hidden}

.home-nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:0 48px;height:64px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(9,9,12,0.85);backdrop-filter:blur(18px);
  border-bottom:1px solid var(--border);
}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-mark{width:34px;height:34px;background:var(--orange);border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:15px;color:white;letter-spacing:1px}
.logo-text{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:20px;letter-spacing:3px;color:var(--white)}
.nav-links{display:flex;align-items:center;gap:32px}
.nav-links a{font-size:13px;color:var(--m2);text-decoration:none;transition:color 0.15s}
.nav-links a:hover{color:var(--white)}
.nav-actions{display:flex;gap:10px;align-items:center}

/* HERO */
.hero{
  min-height:100vh;display:flex;align-items:center;
  position:relative;overflow:hidden;padding:80px 0 0;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 55% 70% at 70% 50%,rgba(240,78,35,0.07) 0%,transparent 60%),
    radial-gradient(ellipse 40% 50% at 10% 80%,rgba(240,78,35,0.04) 0%,transparent 60%),
    var(--bg);
}
.hero-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 20%,transparent 80%);
  opacity:0.5;
}
.hero-inner{
  max-width:1200px;margin:0 auto;padding:0 48px;
  display:grid;grid-template-columns:1fr 480px;align-items:center;gap:60px;width:100%;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--od);border:1px solid rgba(240,78,35,0.25);
  border-radius:20px;padding:5px 14px;
  font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--orange);
  margin-bottom:24px;
}
.hero-tag::before{content:'';width:6px;height:6px;background:var(--orange);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}
.hero-title{
  font-family:'Barlow Condensed',sans-serif;font-weight:900;
  font-size:clamp(56px,7vw,88px);line-height:0.92;letter-spacing:1px;
  margin-bottom:24px;
}
.hero-title em{font-style:normal;color:var(--orange)}
.hero-title .outline{-webkit-text-stroke:1px rgba(242,239,233,0.3);color:transparent}
.hero-sub{font-size:17px;line-height:1.72;color:var(--m2);max-width:460px;margin-bottom:36px}
.hero-actions{display:flex;gap:12px;align-items:center;flex-wrap:wrap}
.hero-stats{display:flex;gap:32px;margin-top:40px;padding-top:32px;border-top:1px solid var(--border)}
.hstat-num{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:28px;color:var(--white);line-height:1}
.hstat-lbl{font-size:11.5px;color:var(--m2);margin-top:2px}

/* Marcus hero card */
.hero-card{
  background:var(--s1);border:1px solid var(--border);border-radius:16px;
  overflow:hidden;position:relative;
}
.hero-img-wrap{position:relative;height:420px;overflow:hidden}
.hero-img{width:100%;height:100%;object-fit:cover;object-position:top center}
.hero-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to bottom,transparent 40%,var(--s1) 100%);
}
.hero-card-body{padding:20px 22px 22px}
.marcus-name-big{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:28px;letter-spacing:2px;margin-bottom:2px}
.marcus-role-text{font-size:12px;color:var(--m2);margin-bottom:12px}
.online-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(29,185,84,0.1);border:1px solid rgba(29,185,84,0.25);border-radius:12px;padding:4px 11px;font-size:11px;color:var(--green);font-family:'JetBrains Mono',monospace}
.online-badge::before{content:'';width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}

/* FEATURES SECTION */
.section{padding:96px 48px;max-width:1200px;margin:0 auto}
.section-tag{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--orange);margin-bottom:14px;display:flex;align-items:center;gap:12px}
.section-tag::before{content:'';display:block;width:28px;height:1px;background:var(--orange)}
.section-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(40px,5vw,64px);line-height:0.95;margin-bottom:16px}
.section-sub{font-size:16px;color:var(--m2);max-width:480px;line-height:1.7}

.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-top:60px}
.feat-card{background:var(--s1);padding:32px 28px;transition:background 0.2s;position:relative;overflow:hidden}
.feat-card:hover{background:var(--s2)}
.feat-icon{font-size:28px;margin-bottom:16px;display:block}
.feat-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:22px;letter-spacing:1px;margin-bottom:10px}
.feat-desc{font-size:13px;color:var(--m2);line-height:1.7}
.feat-tag{position:absolute;top:16px;right:16px;font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1px;text-transform:uppercase;background:var(--od);color:var(--orange);padding:3px 8px;border-radius:3px}

/* MARCUS SECTION */
.marcus-section{padding:96px 0;background:var(--s1);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.marcus-inner{max-width:1200px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:400px 1fr;gap:72px;align-items:center}
.marcus-photo-big{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top center;border-radius:16px;border:1px solid var(--border)}
.trainer-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:32px}
.t-stat{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:16px}
.t-stat-num{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:32px;color:var(--orange);line-height:1}
.t-stat-lbl{font-size:11px;color:var(--m2);margin-top:3px}
.expertise-list{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
.exp-tag{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;background:var(--s2);border:1px solid var(--border);color:var(--m2);padding:5px 11px;border-radius:4px}

/* PRICING SECTION */
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:60px}
.price-card{background:var(--s1);border:1px solid var(--border);border-radius:14px;padding:28px;position:relative;transition:transform 0.2s,border-color 0.2s}
.price-card:hover{transform:translateY(-3px)}
.price-card.pop{border-color:rgba(240,78,35,0.4);background:rgba(240,78,35,0.03)}
.pop-badge{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--orange);color:white;font-family:'JetBrains Mono',monospace;font-size:8.5px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 14px;border-radius:0 0 8px 8px}
.price-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:20px;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px}
.price-amount{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:52px;color:var(--orange);line-height:1}
.price-period{font-size:12px;color:var(--m2);margin-bottom:20px}
.price-feats{display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.pf{display:flex;align-items:flex-start;gap:8px;font-size:12.5px;color:var(--m2)}
.pf.on{color:var(--white)}
.pf-check{font-size:10px;flex-shrink:0;margin-top:2px}
.pf.on .pf-check{color:var(--green)}
.pf.off .pf-check{color:var(--muted)}

/* TESTIMONIALS */
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:60px}
.test-card{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:24px}
.test-stars{color:var(--orange);font-size:12px;letter-spacing:2px;margin-bottom:12px}
.test-text{font-size:13.5px;line-height:1.75;color:var(--white);margin-bottom:18px;font-style:italic}
.test-author{display:flex;align-items:center;gap:10px}
.test-av{width:36px;height:36px;border-radius:50%;object-fit:cover;border:1px solid var(--border)}
.test-name{font-size:13px;font-weight:500}
.test-detail{font-size:10.5px;color:var(--m2);font-family:'JetBrains Mono',monospace;margin-top:1px}

/* CTA SECTION */
.cta-section{
  padding:96px 48px;text-align:center;position:relative;overflow:hidden;
  background:var(--bg);border-top:1px solid var(--border);
}
.cta-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(240,78,35,0.08) 0%,transparent 70%);pointer-events:none}
.cta-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(48px,7vw,80px);line-height:0.95;margin-bottom:16px;position:relative;z-index:2}
.cta-title em{font-style:normal;color:var(--orange)}
.cta-sub{font-size:16px;color:var(--m2);max-width:420px;margin:0 auto 36px;line-height:1.7;position:relative;z-index:2}

/* HOME FOOTER */
.home-footer{background:var(--s1);border-top:1px solid var(--border);padding:32px 48px;display:flex;justify-content:space-between;align-items:center}
.footer-copy{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--m2)}
.footer-links{display:flex;gap:24px}
.footer-links a{font-size:12px;color:var(--m2);text-decoration:none;transition:color 0.15s}
.footer-links a:hover{color:var(--white)}

/* ══════════════════════════════
   AUTH SCREENS
══════════════════════════════ */
#loginScreen,#signupScreen{
  min-height:100vh;display:none;align-items:center;justify-content:center;
  background:var(--bg);position:relative;overflow:hidden;
}
#loginScreen.active,#signupScreen.active{display:flex}
.auth-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 40%,rgba(240,78,35,0.05) 0%,transparent 70%)}
.auth-box{
  background:var(--s1);border:1px solid var(--border);border-radius:16px;
  padding:40px;width:100%;max-width:400px;position:relative;z-index:2;
}
.auth-logo{display:flex;align-items:center;gap:9px;margin-bottom:28px}
.auth-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:28px;letter-spacing:2px;margin-bottom:6px}
.auth-sub{font-size:13px;color:var(--m2);line-height:1.6;margin-bottom:28px}
.auth-field{margin-bottom:14px}
.auth-label{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--m2);margin-bottom:5px}
.auth-input{
  width:100%;background:var(--s2);border:1px solid var(--border);border-radius:7px;
  padding:11px 13px;color:var(--white);font-family:'Barlow',sans-serif;font-size:14px;outline:none;transition:border-color 0.15s;
}
.auth-input:focus{border-color:rgba(240,78,35,0.4)}
.auth-input::placeholder{color:var(--muted)}
.auth-err{color:#f87171;font-size:11.5px;font-family:'JetBrains Mono',monospace;margin-bottom:10px;min-height:16px;display:none}
.auth-err.show{display:block}
.auth-divider{display:flex;align-items:center;gap:12px;margin:18px 0;color:var(--m2);font-size:11px}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border)}
.auth-link{font-size:12.5px;color:var(--m2);text-align:center;margin-top:16px}
.auth-link a{color:var(--orange);text-decoration:none;font-weight:500}
.auth-link a:hover{text-decoration:underline}
.avatar-select{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:6px}
.av-opt{
  aspect-ratio:1;border-radius:10px;border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-size:24px;
  cursor:pointer;transition:all 0.15s;background:var(--s2);
}
.av-opt:hover{border-color:rgba(240,78,35,0.4);background:var(--od)}
.av-opt.selected{border-color:var(--orange);background:var(--od)}
.goal-select{display:flex;flex-direction:column;gap:6px;margin-top:6px}
.goal-opt{
  padding:10px 13px;border:1px solid var(--border);border-radius:7px;
  cursor:pointer;transition:all 0.15s;background:var(--s2);
  font-size:13px;display:flex;align-items:center;gap:9px;
}
.goal-opt:hover{border-color:rgba(240,78,35,0.3);background:var(--od)}
.goal-opt.selected{border-color:var(--orange);background:var(--od);color:var(--white)}
.goal-opt .goal-icon{font-size:16px;flex-shrink:0}

/* ══════════════════════════════
   MAIN APP (dashboard + chat)
══════════════════════════════ */
#appScreen{display:none;height:100vh;overflow:hidden}
#appScreen.active{display:grid;grid-template-columns:64px 1fr}

/* RAIL */
.rail{background:var(--s1);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:12px 0;gap:2px}
.rail-logo{width:36px;height:36px;background:var(--orange);border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:14px;color:white;letter-spacing:1px;margin-bottom:12px;flex-shrink:0}
.rb{width:40px;height:40px;border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;border:none;background:none;color:var(--muted);font-size:17px;transition:all 0.15s;gap:2px}
.rb span{font-size:7px;font-family:'JetBrains Mono',monospace;letter-spacing:0.3px;text-transform:uppercase}
.rb:hover{background:var(--s3);color:var(--white)}
.rb.active{background:var(--od);color:var(--orange)}
.rail-sep{width:26px;height:1px;background:var(--border);margin:5px 0}
.rail-bottom{margin-top:auto}
.user-av-rail{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;transition:border-color 0.15s}
.user-av-rail:hover{border-color:var(--orange)}

/* APP MAIN */
.app-main{display:flex;flex-direction:column;overflow:hidden;min-width:0;height:100vh}
.app-panel{display:none;flex-direction:column;flex:1;overflow:hidden}
.app-panel.active{display:flex}

/* TOPBAR */
.topbar{padding:12px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:rgba(9,9,12,0.95);backdrop-filter:blur(10px);flex-shrink:0;gap:10px}
.tb-l{}
.tb-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:17px;letter-spacing:2px;text-transform:uppercase;line-height:1}
.tb-sub{font-size:11px;color:var(--muted);margin-top:2px;font-family:'JetBrains Mono',monospace}
.tb-r{display:flex;gap:8px;align-items:center;flex-shrink:0}

/* CHAT */
.chat-layout{display:grid;grid-template-columns:1fr 260px;flex:1;overflow:hidden;min-width:0}
.chat-col{display:flex;flex-direction:column;overflow:hidden;border-right:1px solid var(--border);min-width:0}
.msgs{flex:1;overflow-y:auto;padding:18px 16px;display:flex;flex-direction:column;gap:13px}
.msgs::-webkit-scrollbar{width:3px}
.msgs::-webkit-scrollbar-thumb{background:var(--s3)}
.msg{display:flex;gap:9px;animation:msgIn 0.2s ease}
.msg.user{flex-direction:row-reverse;align-self:flex-end;max-width:78%}
.msg.marcus{align-self:flex-start;max-width:90%}
@keyframes msgIn{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
.msg-av{width:28px;height:28px;border-radius:8px;flex-shrink:0;margin-top:2px;overflow:hidden}
.msg.marcus .msg-av{border:1.5px solid rgba(240,78,35,0.3)}
.msg.marcus .msg-av img{width:100%;height:100%;object-fit:cover;object-position:top center}
.msg.user .msg-av{background:var(--s3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:13px}
.bubble{padding:10px 13px;border-radius:10px;font-size:13.5px;line-height:1.72}
.msg.marcus .bubble{background:var(--s1);border:1px solid var(--border);border-radius:10px 10px 10px 3px}
.msg.user .bubble{background:var(--od);border:1px solid rgba(240,78,35,0.18);border-radius:10px 10px 3px 10px}

/* workout card */
.wk-card{background:var(--s2);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-top:10px}
.wk-hd{padding:10px 13px;background:var(--od);border-bottom:1px solid rgba(240,78,35,0.15);display:flex;justify-content:space-between;align-items:center;gap:8px}
.wk-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:2px;text-transform:uppercase;color:var(--orange)}
.wk-tbl{width:100%;border-collapse:collapse;font-size:12.5px}
.wk-tbl th{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);padding:7px 12px;text-align:left;border-bottom:1px solid var(--border)}
.wk-tbl td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
.wk-tbl tr:last-child td{border-bottom:none}
.wk-tbl tr:hover td{background:rgba(255,255,255,0.015)}
.mtag{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1px;text-transform:uppercase;background:var(--od);color:var(--orange);padding:2px 6px;border-radius:3px;display:inline-block}
.plan-card{background:var(--s2);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-top:10px}
.plan-row{display:flex;align-items:flex-start;gap:11px;padding:10px 13px;border-bottom:1px solid var(--border)}
.plan-row:last-child{border-bottom:none}
.plan-day{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--orange);min-width:76px;padding-top:2px}
.plan-focus{font-size:12.5px;font-weight:500}
.plan-exs{font-size:10.5px;color:var(--m2);font-family:'JetBrains Mono',monospace;margin-top:2px;line-height:1.5}

/* quick replies */
.qrs{display:flex;gap:6px;flex-wrap:wrap;padding:7px 16px 0}
.qr{font-size:12px;padding:5px 11px;background:var(--s2);border:1px solid var(--border);border-radius:16px;color:var(--m2);cursor:pointer;transition:all 0.15s;font-family:'Barlow',sans-serif}
.qr:hover{color:var(--white);border-color:rgba(240,78,35,0.35);background:var(--od)}

/* typing */
.typing-bbl{display:flex;gap:4px;padding:2px 0;align-items:center}
.td{width:6px;height:6px;background:var(--muted);border-radius:50%;animation:td 1.1s infinite}
.td:nth-child(2){animation-delay:0.15s}
.td:nth-child(3){animation-delay:0.3s}
@keyframes td{0%,60%,100%{opacity:0.2;transform:scale(0.75)}30%{opacity:1;transform:scale(1)}}

/* input */
.inp-area{padding:10px 16px 14px;border-top:1px solid var(--border);background:var(--bg);flex-shrink:0}
.inp-row{display:flex;gap:8px;align-items:flex-end}
.chat-ta{flex:1;background:var(--s1);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--white);font-family:'Barlow',sans-serif;font-size:13.5px;font-weight:300;resize:none;outline:none;min-height:42px;max-height:104px;line-height:1.5;transition:border-color 0.15s}
.chat-ta:focus{border-color:rgba(240,78,35,0.3)}
.chat-ta::placeholder{color:var(--muted)}
.send-btn{width:42px;height:42px;background:var(--orange);border:none;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all 0.15s;flex-shrink:0}
.send-btn:hover{background:#f5613a;transform:translateY(-1px)}
.send-btn:disabled{background:var(--s3);cursor:not-allowed;transform:none}
.err-bar{background:rgba(239,68,68,0.09);border:1px solid rgba(239,68,68,0.2);border-radius:6px;padding:8px 12px;font-size:11.5px;color:#f87171;margin-bottom:7px;display:none}
.err-bar.show{display:block}

/* right sidebar */
.r-sidebar{overflow-y:auto;display:flex;flex-direction:column;gap:12px;padding:14px;background:var(--bg)}
.r-sidebar::-webkit-scrollbar{width:3px}
.sc{background:var(--s1);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.sc-hd{padding:9px 12px;border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
.sc-bd{padding:12px}

/* marcus sidebar profile */
.m-sidebar-photo{width:100%;aspect-ratio:4/3;object-fit:cover;object-position:top center;border-radius:8px;margin-bottom:10px;border:1px solid var(--border)}
.sdot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sdot.on{background:var(--green);box-shadow:0 0 5px var(--green)}

/* fields */
.field{margin-bottom:9px}
.field:last-child{margin-bottom:0}
.fl{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.fi,.fs{width:100%;background:var(--s2);border:1px solid var(--border);border-radius:6px;padding:7px 9px;color:var(--white);font-family:'Barlow',sans-serif;font-size:13px;outline:none;transition:border-color 0.15s;appearance:none}
.fi:focus,.fs:focus{border-color:rgba(240,78,35,0.3)}
.fs option{background:var(--s2)}

/* DASHBOARD */
.scroll-area{flex:1;overflow-y:auto;padding:18px 20px}
.scroll-area::-webkit-scrollbar{width:3px}
.scroll-area::-webkit-scrollbar-thumb{background:var(--s3)}
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.sc2{background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:14px;position:relative;overflow:hidden}
.sc2::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--orange);transform:scaleX(0);transform-origin:left;transition:transform 0.4s}
.sc2:hover::after{transform:scaleX(1)}
.slbl{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.sval{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:700;line-height:1;color:var(--orange)}
.ssub{font-size:10.5px;color:var(--muted);margin-top:3px}
.dash-grid{display:grid;grid-template-columns:1fr 270px;gap:14px}
.card{background:var(--s1);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.card-hd{padding:11px 15px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.card-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:2px;text-transform:uppercase}
.card-bd{padding:14px}

/* exercise list */
.ex-list{display:flex;flex-direction:column;gap:6px}
.ex-row{display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--s2);border:1px solid var(--border);border-radius:7px;transition:border-color 0.15s;cursor:pointer}
.ex-row:hover{border-color:rgba(240,78,35,0.2)}
.ex-row.done{opacity:0.37}
.ex-row.done .ex-name{text-decoration:line-through}
.ex-num{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--muted);width:19px;flex-shrink:0}
.ex-info{flex:1;min-width:0}
.ex-name{font-size:12.5px;font-weight:500;margin-bottom:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ex-det{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--m2)}
.ex-mt{font-family:'JetBrains Mono',monospace;font-size:7.5px;letter-spacing:1px;text-transform:uppercase;background:var(--od);color:var(--orange);padding:2px 5px;border-radius:3px;flex-shrink:0}
.chk{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:9px;color:transparent;transition:all 0.15s;flex-shrink:0}
.chk:hover{border-color:var(--green);color:var(--green)}
.ex-row.done .chk{background:var(--green);border-color:var(--green);color:white}

.week-row{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-top:3px}
.wd{aspect-ratio:1;border-radius:5px;background:var(--s2);border:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px}
.wd.hit{background:var(--od);border-color:var(--orange)}
.wd.today{border-color:rgba(255,255,255,0.22)}
.wdl{font-family:'JetBrains Mono',monospace;font-size:7px;color:var(--muted)}
.wd.hit .wdl{color:var(--orange)}
.wdi{font-size:9px}

/* history */
.h-tbl{width:100%;border-collapse:collapse}
.h-tbl th{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);padding:9px 13px;text-align:left;border-bottom:1px solid var(--border)}
.h-tbl td{padding:10px 13px;font-size:12.5px;border-bottom:1px solid var(--border)}
.h-tbl tr:last-child td{border-bottom:none}
.h-tbl tr:hover td{background:rgba(255,255,255,0.012)}
.badge{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:0.8px;padding:2px 6px;border-radius:3px;display:inline-block}
.bd{background:rgba(29,185,84,0.1);color:var(--green)}

/* pro badge */
.pro-badge{display:inline-flex;align-items:center;gap:3px;background:linear-gradient(135deg,#F04E23,#ff8c42);color:white;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:9.5px;letter-spacing:1.5px;padding:2px 7px;border-radius:4px;text-transform:uppercase}

/* user menu */
.user-menu{position:absolute;bottom:60px;left:72px;background:var(--s1);border:1px solid var(--border);border-radius:10px;padding:8px;width:200px;z-index:200;box-shadow:0 8px 32px rgba(0,0,0,0.5);display:none}
.user-menu.open{display:block}
.um-header{padding:8px 10px 10px;border-bottom:1px solid var(--border);margin-bottom:4px}
.um-name{font-size:13px;font-weight:500}
.um-email{font-size:10.5px;color:var(--m2);font-family:'JetBrains Mono',monospace}
.um-item{padding:8px 10px;font-size:12.5px;color:var(--m2);cursor:pointer;border-radius:6px;transition:all 0.12s;display:flex;align-items:center;gap:8px}
.um-item:hover{background:var(--s2);color:var(--white)}

/* subscription panel */
.sub-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
.sub-tier{background:var(--s1);border:1px solid var(--border);border-radius:12px;padding:20px;position:relative;transition:all 0.2s}
.sub-tier:hover{transform:translateY(-2px);border-color:rgba(240,78,35,0.25)}
.sub-tier.pop{border-color:rgba(240,78,35,0.4);background:rgba(240,78,35,0.03)}
.sub-tier.pop::before{content:'MOST POPULAR';position:absolute;top:0;left:50%;transform:translateX(-50%);background:var(--orange);color:white;font-family:'JetBrains Mono',monospace;font-size:7.5px;letter-spacing:1.5px;padding:3px 10px;border-radius:0 0 7px 7px}
.stn{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:18px;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px}
.stp{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:40px;color:var(--orange);line-height:1}
.stpe{font-size:11px;color:var(--m2);margin-bottom:14px}
.stf{display:flex;align-items:flex-start;gap:7px;font-size:12px;color:var(--m2);margin-bottom:6px}
.stf.on{color:var(--white)}
.stf::before{content:'✓';color:var(--green);font-size:10px;flex-shrink:0;margin-top:1px;font-weight:700}
.stf.off::before{content:'✗';color:var(--muted)}
.stf.off{color:var(--muted)}

@media(max-width:1024px){
