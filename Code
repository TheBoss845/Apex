  document.getElementById('streakMsg').textContent=msgs[Math.min(S.streak||0,msgs.length-1)];
  if(S.lastSession){document.getElementById('dLast').textContent=S.lastSession.name;document.getElementById('dLastDate').textContent=S.lastSession.date;}
  buildWeekRow();updateGreeting();
}

function buildWeekRow(){
  const wrap=document.getElementById('weekRow');if(!wrap)return;
  const labels=['M','T','W','T','F','S','S'];
  const tidx=new Date().getDay()===0?6:new Date().getDay()-1;
  const dates=Array.from({length:7},(_,i)=>{const d=new Date();d.setDate(d.getDate()-(tidx-i));return d.toLocaleDateString('en-US',{month:'short',day:'numeric'});});
  const hits=(S.history||[]).map(h=>h.date);
  wrap.innerHTML=dates.map((date,i)=>{
    const hit=hits.includes(date),isToday=i===tidx;
    return `<div class="wd ${hit?'hit':''} ${isToday?'today':''}"><span class="wdl">${labels[i]}</span><span class="wdi">${hit?'✓':isToday?'●':''}</span></div>`;
  }).join('');
}

// ═══════════════════════════════════════════
// HISTORY
// ═══════════════════════════════════════════
function buildHistTable(){
  const wrap=document.getElementById('histBody');if(!wrap)return;
  if(!S.history?.length){wrap.innerHTML='<div style="text-align:center;padding:32px;color:var(--muted);font-size:12.5px">No sessions yet.</div>';return;}
  const rows=[...S.history].reverse().map(h=>`<tr>
    <td style="font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--muted)">${h.date}</td>
    <td style="font-weight:500;font-size:12.5px">${h.name}</td>
    <td style="font-family:'JetBrains Mono',monospace;font-size:10.5px">${h.exercises||'—'} exercises</td>
    <td><span class="badge bd">Done</span></td>
  </tr>`).join('');
  wrap.innerHTML=`<table class="h-tbl"><thead><tr><th>Date</th><th>Session</th><th>Volume</th><th>Status</th></tr></thead><tbody>${rows}</tbody></table>`;
  const h=S.history,now=new Date();
  document.getElementById('hTotal').textContent=h.length;
  document.getElementById('hBest').textContent=S.streak||0;
  document.getElementById('hMonth').textContent=h.filter(s=>{try{return new Date(s.date+', '+now.getFullYear()).getMonth()===now.getMonth()}catch(e){return false}}).length;
  document.getElementById('hAvg').textContent=h.length?(h.length/Math.max(1,Math.ceil(h.length/5))).toFixed(1):0;
}

function clearHistory(){
  S.history=[];S.totalSessions=0;S.weekSessions=0;S.streak=0;S.lastSession=null;
  saveState();updateDash();buildHistTable();
}
</script>
